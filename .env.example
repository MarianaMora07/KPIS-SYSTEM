# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Fase 3: tras configurar, ejecutar migraciones:
#   npm run db:reset   (local)  o  supabase db push  (remoto)
# Luego registrarse en /login — el rol "analista" se asigna automáticamente.

# Gemini (Fase 4) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modelo (gemini-2.0-flash fue retirado jun 2026; flash-lite evita truncado por "thinking")
GEMINI_MODEL=gemini-2.5-flash-lite

# Activepieces (Fase 4 — HU-KPI-005 / HU-KPI-008) — ver docs/activepieces-workflows.md
ACTIVEPIECES_WEBHOOK_URL=
# ACTIVEPIECES_WEBHOOK_SECRET=

# Cron jobs (Vercel / scheduler externo)
CRON_SECRET=your-random-secret

# URL pública de la app (enlaces en recordatorios KPI)
# NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# Cache Redis producción (opcional — por defecto in-memory)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
