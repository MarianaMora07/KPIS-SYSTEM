# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Fase 3: tras configurar, ejecutar migraciones:
#   npm run db:reset   (local)  o  supabase db push  (remoto)
# Luego registrarse en /login — el rol "analista" se asigna automáticamente.

# Gemini (Fase 4)
GEMINI_API_KEY=

# n8n webhook base (Fase 4)
N8N_WEBHOOK_URL=
